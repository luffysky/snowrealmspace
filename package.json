{
  "name": "snowrealm-space",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:rls": "vitest run --config vitest.rls.config.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:reset": "tsx scripts/migrate.ts --reset",
    "db:seed": "tsx scripts/seed.ts && tsx scripts/seed-content.ts",
    "invite:create": "tsx scripts/create-invite.ts",
    "check:rls": "tsx scripts/check-rls.ts",
    "check:secrets": "tsx scripts/check-secrets.ts",
    "format": "prettier --write \"**/*.{ts,tsx,css,md,json}\"",
    "check:deps": "depcruise --config .dependency-cruiser.cjs packages apps",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "tsx scripts/free-ports.ts 3100 && playwright test --project=chromium --grep-invert @visual",
    "test:e2e:mobile": "tsx scripts/free-ports.ts 3100 && playwright test --project=mobile --grep-invert @visual",
    "test:a11y": "tsx scripts/free-ports.ts 3100 && playwright test --project=chromium --grep @a11y",
    "e2e:server": "pnpm e2e:build && pnpm e2e:start",
    "e2e:build": "cross-env NEXT_DIST_DIR=.next-e2e NEXT_PUBLIC_APP_URL=http://localhost:3100 dotenv -e .env.local -- pnpm --filter @snowrealm/web exec next build",
    "e2e:start": "cross-env NEXT_DIST_DIR=.next-e2e NEXT_PUBLIC_APP_URL=http://localhost:3100 dotenv -e .env.local -- pnpm --filter @snowrealm/web exec next start -p 3100",
    "ports:free": "tsx scripts/free-ports.ts",
    "fonts:download": "tsx scripts/download-fonts.ts",
    "fonts:build": "tsx scripts/build-fonts.ts",
    "fonts:upload": "dotenv -e .env.local -- tsx scripts/upload-fonts.ts",
    "test:visual": "tsx scripts/free-ports.ts 3100 && cross-env VISUAL=1 playwright test --project=chromium --grep @visual",
    "check:content": "tsx scripts/check-content.ts",
    "seed:content": "tsx scripts/seed-content.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@snowrealm/analytics": "workspace:^",
    "@snowrealm/db": "workspace:^",
    "@snowrealm/shared-types": "workspace:^",
    "@snowrealm/storage": "workspace:^",
    "@snowrealm/theme-engine": "workspace:^",
    "@snowrealm/validation": "workspace:^",
    "@snowrealm/widget-engine": "workspace:^",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "2",
    "adm-zip": "^0.6.0",
    "cross-env": "^10.1.0",
    "dependency-cruiser": "^18.1.0",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.17.0",
    "pg-boss": "^10.1.6",
    "postgres": "^3.4.5",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "subset-font": "^2.5.0",
    "supabase": "^2.109.1",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8",
    "wait-on": "^9.1.0"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
