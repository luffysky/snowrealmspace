# 只放 NEXT_PUBLIC_* —— 這些依定義就是公開值，會被 inline 進 client bundle。
#
# 為什麼需要獨立一份：middleware 跑在 edge runtime，其環境變數是 build 時 inline 的，
# 而 Next 只從「app 目錄」的 .env 檔案讀取。根目錄那份由 dotenv-cli 注入，
# 涵蓋 node runtime（route handler、server component）。
#
# 機密一律只放根目錄的 .env.local，絕不放這裡。
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
