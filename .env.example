# ─── App ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NODE_ENV 刻意不設：由各指令自行決定（next build 需要 production）。

# ─── Supabase ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # 僅伺服器端，絕不可有 NEXT_PUBLIC_ 前綴
DATABASE_URL=                        # worker 與 migration 用

# ─── Cloudflare R2 ──────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=snowrealm-dev
R2_PUBLIC_BASE_URL=
# 本機開發指向 S3 相容的本地服務；production 留空以使用真正的 R2
R2_ENDPOINT=
R2_REGION=auto
R2_FORCE_PATH_STYLE=

# ─── 加密（各為 32 bytes base64）────────────────────────
#   產生方式：node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AI_KEY_ENCRYPTION_SECRET=
TOKEN_ENCRYPTION_SECRET=
CRON_SECRET=                         # 至少 32 字元

# ─── AI Provider（ADR-023：免費優先）────────────────────
# 全部 optional —— 路由層會自動跳過沒有金鑰的候選。
# 開發時只要設一把免費金鑰（建議 GROQ）就能跑起整個產品。
GROQ_API_KEY=
GOOGLE_AI_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
SAMBANOVA_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_TOKEN=
# 付費層，只在升級路徑使用。開發時可留空。
ANTHROPIC_API_KEY=

# ─── Provider OAuth（Milestone F）───────────────────────
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
FIGMA_WEBHOOK_SECRET=

# ─── 第三方登入（13-third-party-auth.md）────────────────
# 全部 optional。沒設的 provider 在登入頁與設定頁會顯示為
# 「尚未設定」並停用，而不是讓 app 起不來。
#
# Google：Supabase 原生支援。除了這裡，還要在
#   本機 supabase/config.toml 的 [auth.external.google]
#   hosted  Dashboard → Authentication → Providers
# 兩邊都設好才會生效。
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# LINE：Supabase 不支援，走自建流程。
# REDIRECT_URI 必須與 LINE Developers Console 設定的**完全一致**，
# 多一個斜線就會被拒絕，且錯誤訊息不會告訴你原因。
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
LINE_LOGIN_REDIRECT_URI=             # 例：https://你的網域/api/auth/line/callback
